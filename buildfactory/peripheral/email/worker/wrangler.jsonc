// Cloudflare Email Worker config — deploy with `wrangler deploy` from this
// directory. Full runbook (bucket create, catch-all rule, operator tokens):
// README.md next to this file.
{
  "name": "foundagent-mail-ingress",
  "main": "index.ts",
  "compatibility_date": "2026-07-01",
  // Email-triggered only — no HTTP surface, so never publish to workers.dev.
  "workers_dev": false,
  "r2_buckets": [
    {
      "binding": "MAIL_BUCKET",
      "bucket_name": "foundagent-mail"
    }
  ]
}
