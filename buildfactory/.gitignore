# Python
__pycache__/
*.pyc
.venv/
.venv-cua/
*.egg-info/
.pytest_cache/

# Per-company mutable state (company wiki + ledger + inbox + claude sessions)
# — one self-contained dir per company; data, NOT code
state/

# VM layer spike / runtime artifacts
vm/shot.png
vm/*.png
vm/logs/
vm/state/
vm/data/

# Secrets / credentials — NEVER commit
.env
.env.*
*.env
secrets.env
identities/
*.credentials.json
*.oat
run/*.env
# Login-state seeds (Playwright storage-state) are credentials too; the
# *.env rules don't cover .json files.
accounts/*/cookies/
# Codex ChatGPT-subscription seed (codex login --device-auth output) — a
# credential like the OAuth token in vm/.env.local, never committed.
accounts/*/codex-auth.json
accounts/*/google-sa.json

# Playwright MCP — browser automation logs/snapshots, not code
.playwright-mcp/

# OS
.DS_Store
