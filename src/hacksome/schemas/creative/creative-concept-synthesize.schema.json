{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["concepts"],
  "properties": {
    "concepts": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "markdown",
          "primary_territory_ref",
          "parent_atom_refs"
        ],
        "properties": {
          "markdown": {"type": "string", "minLength": 1},
          "primary_territory_ref": {
            "type": "string",
            "pattern": "^creative-territory-[0-9]{2}$"
          },
          "parent_atom_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^creative-atom-t[0-9]{2}-[0-9]{2}$"
            }
          }
        }
      }
    }
  }
}
