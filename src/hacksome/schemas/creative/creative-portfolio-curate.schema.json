{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["classifications"],
  "properties": {
    "classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "concept_ref",
          "decision",
          "rationale",
          "possible_duplicate_refs"
        ],
        "properties": {
          "concept_ref": {
            "type": "string",
            "pattern": "^creative-concept-(s[0-9]{2}-[0-9]{2}|m[0-9]{2})-r[0-9]{3}$"
          },
          "decision": {
            "type": "string",
            "enum": ["include", "hold", "exclude"]
          },
          "rationale": {"type": "string", "minLength": 1},
          "possible_duplicate_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^creative-concept-(s[0-9]{2}-[0-9]{2}|m[0-9]{2})-r[0-9]{3}$"
            }
          }
        }
      }
    }
  }
}
