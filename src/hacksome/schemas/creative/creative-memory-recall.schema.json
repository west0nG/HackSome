{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["cues", "no_relevant_memory_reason"],
  "properties": {
    "cues": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cue_id",
          "source_memory_refs",
          "role",
          "transferable_pattern",
          "why_relevant",
          "current_atom_refs",
          "related_concept_refs",
          "elements_that_must_not_be_copied"
        ],
        "properties": {
          "cue_id": {
            "type": "string",
            "pattern": "^memory-cue-[0-9]{2}$"
          },
          "source_memory_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source_run_id",
                "source_route_id",
                "source_contract_version",
                "source_artifact_id",
                "source_artifact_sha256",
                "source_memory_record_artifact_id",
                "source_memory_record_sha256",
                "capsule_sha256"
              ],
              "properties": {
                "source_run_id": {"type": "string", "minLength": 1},
                "source_route_id": {"const": "creative"},
                "source_contract_version": {"enum": ["1", "2"]},
                "source_artifact_id": {"type": "string", "minLength": 1},
                "source_artifact_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "source_memory_record_artifact_id": {
                  "type": "string",
                  "minLength": 1
                },
                "source_memory_record_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "capsule_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                }
              }
            }
          },
          "role": {"type": "string", "enum": ["inspire", "avoid"]},
          "transferable_pattern": {"type": "string", "minLength": 1},
          "why_relevant": {"type": "string", "minLength": 1},
          "current_atom_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^creative-atom-t[0-9]{2}-[0-9]{2}$"
            }
          },
          "related_concept_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^creative-concept-(s[0-9]{2}-[0-9]{2}|m[0-9]{2})-r[0-9]{3}$"
            }
          },
          "elements_that_must_not_be_copied": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "no_relevant_memory_reason": {"type": ["string", "null"], "minLength": 1}
  }
}
