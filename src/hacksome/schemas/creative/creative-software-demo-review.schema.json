{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["overall_decision", "dimensions", "markdown"],
  "properties": {
    "overall_decision": {
      "type": "string",
      "enum": ["pass", "repairable", "invalid"]
    },
    "dimensions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "verdict", "reason_code", "evidence"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": [
              "software_first_core",
              "hardware_independence",
              "technical_demo_substance",
              "end_to_end_demo_path",
              "dependency_integrity",
              "hackathon_scope",
              "core_proof"
            ]
          },
          "verdict": {
            "type": "string",
            "enum": ["pass", "uncertain", "fail"]
          },
          "reason_code": {
            "type": ["string", "null"],
            "enum": [
              null,
              "core_not_software_first",
              "requires_custom_hardware_or_fabrication",
              "core_is_manual_performance_or_installation",
              "no_runnable_end_to_end_demo_path",
              "requires_unavailable_dependency_or_permission",
              "not_buildable_within_hackathon_budget",
              "demo_does_not_prove_core_mechanism"
            ]
          },
          "evidence": {"type": "string", "minLength": 1}
        }
      }
    },
    "markdown": {"type": "string", "minLength": 1}
  }
}
