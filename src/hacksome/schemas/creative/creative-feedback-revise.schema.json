{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["markdown", "primary_territory_ref"],
  "properties": {
    "markdown": {"type": "string", "minLength": 1},
    "primary_territory_ref": {
      "type": "string",
      "pattern": "^creative-territory-[0-9]{2}$"
    }
  }
}
