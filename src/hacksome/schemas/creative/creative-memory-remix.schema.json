{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["concept"],
  "properties": {
    "concept": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "markdown",
            "primary_territory_ref",
            "current_atom_refs",
            "memory_source_refs",
            "cue_refs"
          ],
          "properties": {
            "markdown": {"type": "string", "minLength": 1},
            "primary_territory_ref": {
              "type": "string",
              "pattern": "^creative-territory-[0-9]{2}$"
            },
            "current_atom_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^creative-atom-t[0-9]{2}-[0-9]{2}$"
              }
            },
            "memory_source_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "source_run_id",
                  "source_route_id",
                  "source_contract_version",
                  "source_artifact_id",
                  "source_artifact_sha256",
                  "source_memory_record_artifact_id",
                  "source_memory_record_sha256",
                  "capsule_sha256"
                ],
                "properties": {
                  "source_run_id": {"type": "string", "minLength": 1},
                  "source_route_id": {"const": "creative"},
                  "source_contract_version": {"const": "1"},
                  "source_artifact_id": {"type": "string", "minLength": 1},
                  "source_artifact_sha256": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "source_memory_record_artifact_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_memory_record_sha256": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "capsule_sha256": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  }
                }
              }
            },
            "cue_refs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^memory-cue-[0-9]{2}$"
              }
            }
          }
        }
      ]
    }
  }
}
