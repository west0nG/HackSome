{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hacksome.local/schemas/completion-envelope.schema.json",
  "title": "Long Artifact Completion Envelope",
  "description": "A lightweight terminal result. Long-form artifact content remains in the listed files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "task_id", "status", "output_paths"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "empty"]
    },
    "output_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
