{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hacksome.local/schemas/s1-audience-list.schema.json",
  "title": "S1 Audience List",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "input_language",
    "source_ref",
    "audiences",
    "unknowns"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "input_language": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "audiences": {
      "type": "array",
      "description": "Broad people groups only; entries must not contain imagined tasks, scenarios, pains, products, or technologies.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "audience_id",
          "name",
          "kind",
          "direct_relevance",
          "search_aliases"
        ],
        "properties": {
          "audience_id": {
            "type": "string",
            "pattern": "^audience-[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "profession",
              "population",
              "community",
              "organization_type",
              "life_stage",
              "other"
            ]
          },
          "direct_relevance": {
            "type": "string",
            "minLength": 1
          },
          "search_aliases": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
